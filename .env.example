# ─────────────────────────────────────────────────────────────────
# FUN-ISRAEL environment variables
# Copy this file to `.env.local` for local dev,
# and configure these in your Vercel/Netlify project settings for prod.
# ─────────────────────────────────────────────────────────────────

# ── Site URL (used for canonical, sitemap, OG, schema) ───────────
# After connecting a real domain, set this to the live https URL.
NEXT_PUBLIC_SITE_URL=https://fun-israel.co.il

# ── Contact ──────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=972509331313
NEXT_PUBLIC_PHONE_NUMBER=050-933-1313
NEXT_PUBLIC_PICKUP_ADDRESS=דרך יבנה 52

# ── Admin panel password (basic gate, change before launch) ──────
NEXT_PUBLIC_ADMIN_PASSWORD=funisrael2026

# ── Reservation email notifications (server-only secrets) ────────
# These are read by /api/reservation. Without them, the form still
# works (WhatsApp handoff) but no email is sent to you.
#
# 1. Sign up free at https://resend.com → API Keys → Create
RESEND_API_KEY=

# 2. Where reservation emails go. Defaults to zehavialon4@gmail.com
RESERVATION_NOTIFICATION_EMAIL=zehavialon4@gmail.com

# 3. Sender shown to you. Use the Resend sandbox until you verify
#    your real domain in Resend → Domains.
#    Once verified, change to: "FUN-ISRAEL <hello@fun-israel.co.il>"
RESERVATION_FROM_EMAIL=FUN-ISRAEL <onboarding@resend.dev>
